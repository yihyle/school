# ───────────────────────────────────────────────────────────────
# application.yml 예시 파일
#
# 실제 application.yml 은 비밀값(DB 비밀번호, JWT 시크릿 등) 보호를 위해
# .gitignore 처리되어 저장소에 포함되지 않습니다.
#
# 사용법:
#   cp application.yml.example application.yml
#   (필요 시 DB 접속정보·시크릿을 환경에 맞게 수정)
#
# 모든 값은 ${ENV_VAR:기본값} 형태라 환경변수로 덮어쓸 수 있습니다.
# 로컬은 기본값으로 바로 실행되고, 운영은 환경변수로 주입합니다.
# ───────────────────────────────────────────────────────────────
spring:
  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:mysql://localhost:3306/learnhub?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true&characterEncoding=UTF-8}
    username: ${SPRING_DATASOURCE_USERNAME:root}
    password: ${SPRING_DATASOURCE_PASSWORD:1234}        # 로컬 개발용 기본값 — 운영은 반드시 환경변수로 교체
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: validate
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQLDialect
        format_sql: true
    show-sql: false

  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true

  servlet:
    multipart:
      max-file-size: 500MB
      max-request-size: 500MB

springdoc:
  api-docs:
    path: /v3/api-docs
  swagger-ui:
    path: /swagger-ui.html
    tags-sorter: alpha
    operations-sorter: alpha

jwt:
  secret: ${JWT_SECRET:learnhub-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256}  # 운영은 32자 이상 랜덤 시크릿으로 교체
  expiration: ${JWT_EXPIRATION:3600000}

server:
  port: 8080

upload:
  dir: ${UPLOAD_DIR:uploads}

cors:
  allowed-origins: ${CORS_ALLOWED_ORIGINS:http://localhost:3000}

# P3 ─ 외부 알림 (디스코드 Webhook)
discord:
  webhook-url: ${DISCORD_WEBHOOK_URL:}        # 비어 있으면 발송을 건너뛰고 로그만 남김(로컬 안전)
  username: LearnHub Bot

# P3 ─ 알림 디스패치 정책
notification:
  max-retry: ${NOTIFICATION_MAX_RETRY:3}

# P3 ─ 결제 (토스페이먼츠 테스트 모드)
# 기본값 TOSS: 프론트 결제위젯 + 토스 공용 docs 테스트키로 실연동 동작(인터넷 필요).
# 오프라인/발표 안정성 우선 시 PAYMENT_PROVIDER=MOCK 으로 전환하면 외부 호출 없이 승인 처리.
payment:
  provider: ${PAYMENT_PROVIDER:TOSS}          # MOCK | TOSS
  toss:
    # 토스페이먼츠 공식 문서 공용 테스트 시크릿 키(위젯 docs 키쌍). 프론트 클라이언트 키와 쌍을 이룸.
    secret-key: ${TOSS_SECRET_KEY:test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6}
    confirm-url: https://api.tosspayments.com/v1/payments/confirm

# P3 ─ 관측성 (Actuator)
management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics
  endpoint:
    health:
      show-details: when_authorized
  info:
    env:
      enabled: true

info:
  app:
    name: LearnHub
    phase: P3
